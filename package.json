{
  "name": "gestordesk",
  "private": true,
  "version": "1.5.2",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "sync:full": "electron scripts/full-resync.cjs",
    "clean:db": "node scripts/clean-db-before-build.cjs",
    "cleanup:supabase:produtos": "node scripts/cleanup-supabase-produtos-synced-zero.cjs",
    "seed:produtos": "electron scripts/seed-produtos.cjs",
    "seed:vendas": "electron scripts/seed-vendas.cjs",
    "seed:clear": "electron scripts/clear-seeds.cjs",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "electron .",
    "start": "concurrently \"npm run dev\" \"npm run electron\"",
    "postinstall": "electron-rebuild",
    "dist": "npm run build && node scripts/build-installer.cjs",
    "dist:clean": "npm run clean:db && npm run build && node scripts/build-installer.cjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^16.6.1",
    "jsbarcode": "^3.12.3",
    "jspdf": "^4.2.0",
    "react": "^19.2.0",
    "react-barcode": "^1.6.1",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^40.6.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "com.gestordesk.app",
    "productName": "GestorDesk",
    "files": [
      "dist/**",
      "electron/**",
      "database.db",
      "package.json"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GestorDesk"
    }
  }
}
